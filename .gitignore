# storage/ holds data, caches, logs, results (big / regenerable) - untracked.
# Exclude the children (not storage/ itself) so storage/figures/*.png re-includes.
/storage/*
!/storage/figures/
/storage/figures/*
!/storage/figures/*.png

# secrets + project-local environments
.env
/.venv/
# rv-installed R packages (rv/.gitignore also ignores it); rproject.toml + rv.lock + rv/scripts/ stay tracked
/rv/library/
# pinned project-local binaries (rv, quarto); regenerate via scripts/bootstrap/*.sh
/tools/

# legacy/default targets store (current _targets.yaml routes it to storage/targets)
/_targets/
# Quarto render artefacts (regenerate via tar_make / quarto render)
/report/
/_freeze/
/.quarto/
**/*.quarto_ipynb
# optional code-graph index; regenerable, never source
/.tokensave/

# generic R artefacts
.Rhistory
.RData
.Rproj.user/
*.Rcheck/
Rplots.pdf
/*.html

# generic Python artefacts
__pycache__/
*.py[cod]
