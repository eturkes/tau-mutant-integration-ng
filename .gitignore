# storage/ holds data, caches, logs, results (big / regenerable) - untracked.
# Exclude the children (not storage/ itself) so storage/figures/*.png re-includes.
/storage/*
!/storage/figures/
/storage/figures/*
!/storage/figures/*.png

# secrets + project-local environments
.env
/.venv/
# rv-installed R packages (rv/.gitignore also ignores it); rproject.toml + rv.lock + rv/scripts/ stay tracked
/rv/library/
# pinned project-local binaries (rv, quarto); regenerate via scripts/install-*.sh
/tools/

# targets store + Quarto render artefacts (regenerate via tar_make / quarto render)
/_targets/
/_book/
/_freeze/
/.quarto/
**/*.quarto_ipynb

# generic R artefacts
.Rhistory
.RData
.Rproj.user/
*.Rcheck/
Rplots.pdf
/*.html

# Claude state: track settings.json + commands/, ignore the rest
/.claude/*
!/.claude/settings.json
!/.claude/commands/
